# Copy to .env and adjust. Consumed by internal/config.Load().
# Required vars have no default — the server refuses to start without them.
#
# Deploying to another box? Every host below is just a value here — no IP is
# hardcoded in code. Single-box deploy = keep everything on localhost (same .env
# on every customer machine). See docs/deployment-config.md for the single-box /
# docker-compose / DNS presets and the read-only consumer DB role.

# --- required ---
# Port 5433 matches docker-compose.yml (host 5433 -> container 5432), chosen to
# avoid colliding with a host-installed Postgres on 5432.
CRN_DATABASE_URL=postgres://crn:crn_dev_password@localhost:5433/crn?sslmode=disable
# Apple Silicon Homebrew: /opt/homebrew/bin/claude ; Intel/Linux: /usr/local/bin/claude
CRN_CLAUDE_BIN=/usr/local/bin/claude
CRN_DOCKER_USER=your-dockerhub-username

# --- optional (defaults shown) ---
CRN_LISTEN_ADDR=:8080
# Central "DB กลาง"; defaults to CRN_DATABASE_URL during standalone dev.
CRN_CENTRAL_DATABASE_URL=
CRN_MONGO_URL=mongodb://crn:crn_dev_password@localhost:27017
CRN_PROJECTS_DIR=./.crn-workspaces
# Git remote the per-build branch is force-pushed to. Empty -> push step skipped.
# Uses the ambient host git credentials; no token is injected by CRN.
# Used only in the shared-remote model (when CRN_GITHUB_OWNER is empty).
CRN_GIT_REMOTE=https://github.com/your-org/your-repo.git
# "One private GitHub repo per project" model (opt-in). When set, each project
# gets its OWN repo "crn-<slug>-<id8>" under this owner and builds/edits push to
# that repo's "main" (via the authenticated host `gh` CLI, scopes incl. repo);
# GitHub issues endpoints become active. Empty -> the shared-remote model above.
CRN_GITHUB_OWNER=
# When CRN_GITHUB_OWNER is set, create per-project repos as private (default) or
# public. Ignored when CRN_GITHUB_OWNER is empty.
CRN_REPO_PRIVATE=true
# Run Claude Code after materializing files? Defaults to true (a real Claude
# session runs the fitt-build harness skill). Set "false"/"0" to skip Claude and
# only materialize + push.
CRN_RUN_CLAUDE=true
# Pin the model the spawned `claude` uses. Empty = the CLI default. Set to
# "sonnet" (latest Sonnet — cheaper/faster than Opus) or a full model id.
CRN_CLAUDE_MODEL=
CRN_LOG_LEVEL=info
CRN_SHUTDOWN_TIMEOUT=15s
CRN_ENV=development
# Shell spawned for the interactive per-project terminal WebSocket
# (GET /internal/projects/{id}/terminal). Empty -> $SHELL, then /bin/zsh, then
# /bin/bash, then /bin/sh (first that exists on the host).
CRN_TERMINAL_SHELL=
# FTC DV build-status callback (optional). When the URL is set, CRN POSTs
# {status: building|released|failed, job_id, build_no, image_ref?, message?} to
# FTC DV after each build transition — IN ADDITION to the build_events fan-out.
# Empty URL -> callback disabled. (The zip_uri ingest field is always accepted.)
CRN_FTC_DV_CALLBACK_URL=
CRN_FTC_DV_CALLBACK_TOKEN=
# Docker-image pipeline (opt-in). When true, after a successful build CRN runs
# `docker build` on the produced Next standalone app into an OPAQUE image (only
# compiled output — no source ships) and, if CRN_IMAGE_REGISTRY is set,
# `docker push`. Requires a Docker daemon on the CRN host + a prior
# `docker login <registry>`. Empty registry = build locally only (no push).
#   CRN_IMAGE_REGISTRY=registry.gitlab.local/fitt   (tag: <reg>/crn-demo-<slug>:v<n>)
CRN_BUILD_IMAGE=false
CRN_IMAGE_REGISTRY=
# Air-gap bundle output. When set, each build also writes
# <CRN_ARTIFACT_DIR>/<repo>-v<n>/ with images.tar (docker save of app+migrate) +
# docker-compose.customer.yml + INSTALL.md — for customers who can't pull from
# the registry (docker load < images.tar). Empty -> registry delivery only.
CRN_ARTIFACT_DIR=
