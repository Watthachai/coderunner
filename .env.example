# Copy to .env and adjust. Consumed by internal/config.Load().
# Required vars have no default — the server refuses to start without them.

# --- required ---
CRN_DATABASE_URL=postgres://crn:crn_dev_password@localhost:5432/crn?sslmode=disable
CRN_CLAUDE_BIN=/usr/local/bin/claude
CRN_DOCKER_USER=your-dockerhub-username

# --- optional (defaults shown) ---
CRN_LISTEN_ADDR=:8080
# Central "DB กลาง"; defaults to CRN_DATABASE_URL during standalone dev.
CRN_CENTRAL_DATABASE_URL=
CRN_MONGO_URL=mongodb://crn:crn_dev_password@localhost:27017
CRN_PROJECTS_DIR=/projects
CRN_LOG_LEVEL=info
CRN_SHUTDOWN_TIMEOUT=15s
CRN_ENV=development
